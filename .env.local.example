# Supabase - get from supabase.com dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Server-only key for the Lemon Squeezy webhook (Settings → API → service_role).
# NEVER expose this to the browser / never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Anthropic - get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Lemon Squeezy - get from lemonsqueezy.com
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_key_here
NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID=your_store_id_here
NEXT_PUBLIC_LEMONSQUEEZY_PRODUCT_ID=your_product_id_here
# Webhook signing secret (Lemon Squeezy → Settings → Webhooks)
LEMONSQUEEZY_WEBHOOK_SECRET=your_lemonsqueezy_webhook_secret_here
